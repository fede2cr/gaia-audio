# ── Build stage ─────────────────────────────────────────────────────
FROM debian:trixie AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates \
    pkg-config libssl-dev \
    gcc g++ libc6-dev \
    && rm -rf /var/lib/apt/lists/*

ENV RUSTUP_HOME=/usr/local/rustup CARGO_HOME=/usr/local/cargo
ENV PATH="/usr/local/cargo/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable

WORKDIR /build

# Copy workspace manifests first for dependency caching
COPY Cargo.toml Cargo.lock ./
COPY common/Cargo.toml common/Cargo.toml
COPY capture/Cargo.toml capture/Cargo.toml
COPY processing/Cargo.toml processing/Cargo.toml
COPY web/Cargo.toml web/Cargo.toml

# Create dummy sources so cargo can fetch/compile dependencies
RUN mkdir -p common/src capture/src processing/src web/src && \
    echo "pub fn _dummy() {}" > common/src/lib.rs && \
    echo "fn main() {}" > capture/src/main.rs && \
    echo "fn main() {}" > processing/src/main.rs && \
    echo "pub fn _dummy() {}" > web/src/lib.rs && \
    echo "fn main() {}" > web/src/main.rs && \
    cargo build --release -p gaia-processing 2>/dev/null || true

# Copy real source (touch to invalidate cargo fingerprint from dummy layer)
COPY common/src common/src
COPY processing/src processing/src
RUN touch common/src/lib.rs processing/src/main.rs

# Build for real
RUN cargo build --release -p gaia-processing

# ── Keras → ONNX conversion at build time ─────────────────────────
# Downloads the BirdNET V2.4 Keras model from Zenodo, splits at the
# concatenate layer (removing the RFFT-based mel-spectrogram layers),
# and converts only the CNN classifier to ONNX.
#
# The resulting ~49 MB ONNX file is baked into the image.  No Python
# or TensorFlow is needed at runtime — the mel-spectrogram
# preprocessing runs in native Rust (mel.rs).
# Use Python 3.11 + TF 2.15 (last release with built-in Keras 2).
# TF 2.16+ split Keras out to tf_keras, which has deserialization bugs
# with BirdNET V2.4's MelSpecLayerSimple functional graph.
FROM python:3.11-slim AS converter

RUN pip install --no-cache-dir 'pycparser<3' && \
    pip install --no-cache-dir 'tensorflow==2.15.*' 'onnx<1.17' tf2onnx onnxruntime

WORKDIR /convert
COPY scripts/convert_keras_to_onnx.py .
COPY scripts/download_meta_tflite.py .
COPY scripts/validate_onnx.py .

# Download Keras zip from Zenodo and extract (flatten directory structure).
# python:3.12-slim does not include curl, so we use urllib instead.
RUN python3 -c "\
import urllib.request, zipfile, os, shutil; \
print('Downloading BirdNET V2.4 Keras model from Zenodo...'); \
urllib.request.urlretrieve( \
    'https://zenodo.org/api/records/15050749/files/BirdNET_v2.4_keras.zip/content', \
    'keras.zip'); \
z = zipfile.ZipFile('keras.zip'); \
z.extractall('/convert/keras_raw'); \
os.makedirs('/convert/keras', exist_ok=True); \
[shutil.copy2(os.path.join(r,f), '/convert/keras/'+f) \
 for r,_,fs in os.walk('/convert/keras_raw') \
 for f in fs \
 if not r.endswith('__MACOSX') and not f.startswith('._')]; \
os.remove('keras.zip'); \
shutil.rmtree('/convert/keras_raw')" && \
    ls -lh /convert/keras/

# Extract en_us.txt labels from the Keras zip (for species-range filtering).
# The labels/ directory is flattened alongside the .h5 files.
RUN cp /convert/keras/en_us.txt /convert/en_us.txt && \
    echo "Extracted labels: $(wc -c < /convert/en_us.txt) bytes → /convert/en_us.txt"

# Convert classifier sub-model to ONNX (Keras → split at concatenate → ONNX)
RUN python3 convert_keras_to_onnx.py /convert/keras -o audio-model.onnx && \
    mv /convert/keras/audio-model.onnx /convert/audio-model.onnx && \
    ls -lh /convert/audio-model.onnx

# Convert metadata model to ONNX.
# The meta-model.h5 uses a custom MDataLayer — our convert script provides
# a stub implementation so we can convert directly from Keras to ONNX
# without needing a separate TFLite download.
RUN python3 convert_keras_to_onnx.py /convert/keras -o meta-model.onnx --meta-only && \
    mv /convert/keras/meta-model.onnx /convert/meta-model.onnx && \
    ls -lh /convert/meta-model.onnx

# Validate converted ONNX models with onnxruntime before continuing.
# audio-model.onnx: classifier input = (1, 96, 511, 2) mel spectrogram
# meta-model.onnx:  input = (1, 3)  lat, lon, week
RUN python3 validate_onnx.py /convert/audio-model.onnx --shape 1,96,511,2 && \
    python3 validate_onnx.py /convert/meta-model.onnx   --shape 1,3

# ── BatDetect2 PyTorch → ONNX conversion at build time ────────────
# Downloads the batdetect2 pip package (includes the ~7.6 MB PyTorch
# checkpoint), exports the model to ONNX using torch.onnx.export,
# and extracts the species class labels.
#
# Uses a separate stage with PyTorch to keep the runtime image lean.
FROM python:3.11-slim AS batconverter

RUN pip install --no-cache-dir batdetect2 onnx onnxruntime

WORKDIR /convert
COPY scripts/convert_batdetect2_to_onnx.py .
COPY scripts/validate_onnx.py .
RUN python3 convert_batdetect2_to_onnx.py --output-dir /convert && \
    ls -lh /convert/batdetect2.onnx /convert/labels.csv

# Validate BatDetect2 ONNX: input = (1, 1, 128, 256) pre-computed spectrogram
RUN python3 validate_onnx.py /convert/batdetect2.onnx --shape 1,1,128,256

# ── BirdNET+ V3.0 ONNX patch at build time ────────────────────────
# Downloads the BirdNET+ V3.0 ONNX model from Zenodo, patches
# Resize nodes and freezes symbolic dimensions to concrete values
# for tract-onnx compatibility, then validates the result with
# onnxruntime.
#
# The resulting ~516 MB ONNX file is baked into the image.
# No Python is needed at runtime.
FROM python:3.11-slim AS birdnet3converter

RUN pip install --no-cache-dir onnx onnxruntime numpy

WORKDIR /convert
COPY scripts/patch_birdnet3_onnx.py .
COPY scripts/validate_onnx.py .
RUN python3 patch_birdnet3_onnx.py -o /convert/birdnet3.onnx && \
    ls -lh /convert/birdnet3.onnx

# Validate BirdNET+ V3.0 ONNX: input = (1, 96000) raw audio at 32 kHz × 3s
RUN python3 validate_onnx.py /convert/birdnet3.onnx --shape 1,96000

# ── ONNX Runtime shared library ───────────────────────────────────
# When tract-onnx cannot handle a model (e.g. DFT/STFT ops in BirdNET
# V3, Perch), the processing server falls back to ONNX Runtime via the
# `ort` crate.
#
# IMPORTANT: we extract libonnxruntime.so from the Python pip package
# rather than the GitHub releases tarball.  The pip-bundled build
# handles DFT/STFT models correctly, while the tarball build hangs
# indefinitely in CreateSession for those same models.
#
# VERSION PIN: ort-sys 2.0.0-rc.12 generates FFI bindings for ORT C API v17
# and ships prebuilt binaries for ORT 1.24.2 (see dist.txt:  ms@1.24.2).
# With `load-dynamic`, the crate loads whatever libonnxruntime.so is on
# the system.  While API v17 is forward-compatible, newer ORT releases
# can change internal thread-pool / graph-analysis behaviour, causing
# the same CreateSession deadlocks we previously fixed.  Pin to the
# exact version ort-sys targets to guarantee identical behaviour.
FROM python:3.11-slim AS ort-download
RUN pip install --no-cache-dir 'onnxruntime==1.24.2' && \
    ORT_LIB=$(python3 -c "import onnxruntime; import os; print(os.path.join(os.path.dirname(onnxruntime.__file__), 'capi'))") && \
    cp "${ORT_LIB}"/libonnxruntime.so* /usr/lib/ && \
    ls -lh /usr/lib/libonnxruntime.so* && \
    ldconfig

# ── tract-onnx dry-run validation ──────────────────────────────────
# Actually load every ONNX model through tract-onnx (the runtime
# inference engine) to catch incompatibilities that the Python
# validator cannot detect — e.g. "shape input is variable", unsupported
# ops, or broken shape inference.
#
# This uses the same code path as the production server (load →
# optimise → runnable).  Any model that fails here WILL fail at
# deployment time, so we abort the build early.
#
# NOTE: BirdNET+ V3.0 (birdnet3.onnx) uses DFT/STFT ops that
# tract-onnx does not support — it falls back to ONNX Runtime at
# runtime.  We skip it here; it was already validated with
# onnxruntime in the birdnet3converter stage.
FROM debian:trixie-slim AS tract-validator
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder    /build/target/release/gaia-processing /usr/local/bin/gaia-processing
COPY --from=converter  /convert/audio-model.onnx /validate/audio-model.onnx
COPY --from=converter  /convert/meta-model.onnx  /validate/meta-model.onnx
COPY --from=batconverter /convert/batdetect2.onnx /validate/batdetect2.onnx
RUN gaia-processing validate-model \
        /validate/audio-model.onnx \
        /validate/meta-model.onnx \
        /validate/batdetect2.onnx && \
    touch /validate/.tract-ok

# ── End-to-end smoke test ──────────────────────────────────────────
# Uses a baked-in recording of Keel-billed Toucan (Ramphastos
# sulfuratus) from test-fixtures/, assembles all bird models with
# their manifests and labels, then runs real inference through every
# model.  Asserts that:
#   1. Every model detects the expected species in its top-5.
#   2. Confidence scores are in a sane range (not near-zero garbage).
#   3. All models agree within a reasonable confidence spread.
#
# All models (BirdNET V2.4, V3.0, Perch) are validated through the
# Rust binary using the native `ort` crate with explicit thread
# limits (inter=1, intra=4) to prevent CreateSession deadlocks on
# DFT/STFT models.
#
# Adds ~2–3 minutes to the build (model downloads + inference).
# To skip during rapid iteration: podman build --target runtime …
FROM debian:trixie-slim AS smoke-test-runner
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates ffmpeg curl && rm -rf /var/lib/apt/lists/*

# Binary + ORT library
COPY --from=builder      /build/target/release/gaia-processing /usr/local/bin/gaia-processing
COPY --from=ort-download /usr/lib/libonnxruntime.so*           /usr/lib/
RUN ldconfig

# ── Convert baked-in test audio to WAV ────────────────────────────
# Source: Keel-billed Toucan (Ramphastos sulfuratus) from a live
# gaia-audio deployment, ~20 s of verified detections.
WORKDIR /test
COPY processing/test-fixtures/smoke-test-bird.opus /test/bird.opus
RUN ffmpeg -y -i /test/bird.opus -ac 1 -ar 48000 -c:a pcm_s16le /test/bird.wav && \
    echo "Test audio: $(du -h /test/bird.wav | cut -f1), $(ffprobe -v error -show_entries format=duration -of csv=p=0 /test/bird.wav)s"

# ── Assemble BirdNET V2.4 model directory ─────────────────────────
COPY examples/birds_manifest.toml /test/models/birdnet/manifest.toml
COPY --from=converter /convert/audio-model.onnx /test/models/birdnet/audio-model.onnx
COPY --from=converter /convert/meta-model.onnx  /test/models/birdnet/meta-model.onnx
COPY --from=converter /convert/en_us.txt        /test/models/birdnet/en_us.txt

# ── Assemble BirdNET+ V3.0 model directory ────────────────────────
COPY examples/birdnet3_manifest.toml /test/models/birdnet3/manifest.toml
COPY --from=birdnet3converter /convert/birdnet3.onnx  /test/models/birdnet3/birdnet3.onnx
COPY --from=converter /convert/meta-model.onnx        /test/models/birdnet3/meta-model.onnx
COPY --from=converter /convert/en_us.txt              /test/models/birdnet3/meta-labels.txt
# Download V3.0 labels (small CSV, ~600 KB)
RUN curl -fsSL -o /test/models/birdnet3/labels.csv \
    "https://zenodo.org/api/records/18247420/files/BirdNET%2B_V3.0-preview3_Global_11K_Labels.csv/content" && \
    echo "BirdNET V3.0 labels: $(wc -l < /test/models/birdnet3/labels.csv) lines"

# ── Assemble Perch V2.0 model directory ───────────────────────────
COPY examples/perch_manifest.toml /test/models/perch/manifest.toml
# Download Perch ONNX model (~68 MB) and labels from HuggingFace.
RUN curl -fsSL -o /test/models/perch/model.onnx \
    "https://huggingface.co/justinchuby/Perch-onnx/resolve/main/perch_v2.onnx" && \
    ls -lh /test/models/perch/model.onnx
RUN curl -fsSL -o /test/models/perch/labels.csv \
    "https://huggingface.co/cgeorgiaw/Perch/resolve/main/assets/labels.csv" && \
    echo "Perch labels: $(wc -l < /test/models/perch/labels.csv) lines"

# ── Run smoke tests ──────────────────────────────────────────────
# Single invocation covers ALL bird models through the exact same
# Rust code path used at runtime (model::load_model → OrtSession::
# new_cpu → predict).  No special-casing, no Python, no env-var
# overrides — so regressions like thread-pool deadlocks or library-
# discovery failures are caught here before the image is published.
#
# NOTE: ORT_DYLIB_PATH is intentionally NOT set here.  The runtime
# stage relies on ldconfig to find libonnxruntime.so, so the smoke
# test must do the same to verify the library is properly installed.
#
# timeout 300 (5 min): prevents indefinite hangs if an ORT version
# regression reintroduces the CreateSession deadlock.  Normal smoke
# tests complete in under 60 seconds.
RUN RUST_LOG=info \
    timeout 300 \
    gaia-processing smoke-test \
        --audio /test/bird.wav \
        --models /test/models \
        --species "Ramphastos sulfuratus" && \
    touch /test/.smoke-ok

# ── Runtime stage ──────────────────────────────────────────────────
# Rust binary + pre-converted ONNX models.  No Python at runtime —
# all inference (including DFT/STFT models like BirdNET V3 and Perch)
# runs natively through the `ort` crate with explicit thread limits.
FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/gaia-processing /usr/local/bin/gaia-processing

# Force Docker to run test stages (they are otherwise skipped because
# nothing in the final image references them).  These sentinel files
# are only created when the tests pass.
COPY --from=tract-validator    /validate/.tract-ok /tmp/.tract-ok
COPY --from=smoke-test-runner  /test/.smoke-ok     /tmp/.smoke-ok

# ONNX Runtime shared library for native Rust inference.
# Extracted from the pip onnxruntime package in the ort-download stage.
COPY --from=ort-download /usr/lib/libonnxruntime.so* /usr/lib/
RUN ldconfig

# Pre-converted BirdNET V2.4 classifier ONNX model (~49 MB).
# At runtime, ensure_onnx_file() copies this to the model directory
# if the manifest requests audio-model.onnx and it is absent.
COPY --from=converter /convert/audio-model.onnx /usr/local/share/gaia/models/audio-model.onnx

# Pre-converted BirdNET V2.4 metadata ONNX model (~28 MB).
# Location-based species filtering without tract-tflite STRIDED_SLICE issues.
COPY --from=converter /convert/meta-model.onnx /usr/local/share/gaia/models/meta-model.onnx

# Pre-converted BatDetect2 ONNX model (~7.6 MB) + species labels.
# The PyTorch checkpoint is exported to ONNX at build time in the
# batconverter stage, so no Python/PyTorch is needed at runtime.
COPY --from=batconverter /convert/batdetect2.onnx  /usr/local/share/gaia/models/batdetect2.onnx
COPY --from=batconverter /convert/labels.csv        /usr/local/share/gaia/models/batdetect2-labels.csv

# Pre-patched BirdNET+ V3.0 ONNX model (~541 MB).
# Resize nodes patched: pytorch_half_pixel → half_pixel for tract-onnx.
# At runtime, ensure_onnx_file() copies this to the model directory.
COPY --from=birdnet3converter /convert/birdnet3.onnx /usr/local/share/gaia/models/birdnet3.onnx

# Bundle all model manifests so the entrypoint can seed them into the
# models volume automatically.  Each manifest goes into its own
# subdirectory matching the slug used at runtime.
COPY examples/birds_manifest.toml    /usr/local/share/gaia/manifests/birdnet/manifest.toml
COPY examples/perch_manifest.toml    /usr/local/share/gaia/manifests/perch/manifest.toml
COPY examples/bats_manifest.toml     /usr/local/share/gaia/manifests/batdetect2/manifest.toml
COPY examples/birdnet3_manifest.toml /usr/local/share/gaia/manifests/birdnet3/manifest.toml
# Reuse BirdNET V2.4 metadata model + labels for species-range filtering in V3.
COPY --from=converter /convert/meta-model.onnx /usr/local/share/gaia/manifests/birdnet3/meta-model.onnx
# The V2.4 meta-model uses V2.4 labels (en_us.txt); bundle them separately
# so the meta-model output maps to the correct species names.
COPY --from=converter /convert/en_us.txt /usr/local/share/gaia/manifests/birdnet3/meta-labels.txt

# Seed batdetect2 labels alongside the manifest so entrypoint.sh copies
# them into /models/batdetect2/ (no-clobber) at container start.
COPY --from=batconverter /convert/labels.csv /usr/local/share/gaia/manifests/batdetect2/labels.csv

RUN mkdir -p /etc/gaia /data /models

# Default config — override by mounting your own
RUN echo '# Gaia Processing Server config\n\
LATITUDE=-1\n\
LONGITUDE=-1\n\
CONFIDENCE=0.7\n\
SENSITIVITY=1.25\n\
OVERLAP=0.0\n\
MODEL_DIR=/models\n\
DATABASE_LANG=en\n\
DB_PATH=/data/detections.db\n\
CAPTURE_SERVER_URL=http://capture:8089\n\
POLL_INTERVAL_SECS=5\n\
RECS_DIR=/data\n\
EXTRACTED=/data/extracted\n' > /etc/gaia/gaia.conf

# Entrypoint script seeds bundled manifests into the models volume
# (no-clobber) before starting the processing server.
COPY processing/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

VOLUME ["/data", "/models"]

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["/etc/gaia/gaia.conf"]
